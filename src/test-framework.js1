/* eslint-disable no-console */
/* eslint-disable no-shadow */
/* eslint-disable strict */
async function test(message, cb) {
  try {
    await cb();
    console.log(`${message} Ok`);
  } catch (e) {
    console.log(message);
    console.error(e);
  }
}

function expect(actual) {
  return {
    toBe(expected) {
      if (actual !== expected) {
        throw new Error(`Result ${actual} is not equal expected ${expected}!`);
      }
    },
  };
}

global.test = test;
global.expect = expect;
